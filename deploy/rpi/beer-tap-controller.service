[Unit]
Description=Beer Tap Controller
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/beer-tap-system/rpi-controller
Environment=PYTHONUNBUFFERED=1
Environment=DEVICE_ENV_PATH=/etc/beer-tap/device.env
ExecStartPre=/bin/mkdir -p /run/beer-tap
ExecStart=/opt/beer-tap-system/.venv-controller/bin/python main.py
Restart=always
RestartSec=3
User=pi
Group=pi

[Install]
WantedBy=multi-user.target
