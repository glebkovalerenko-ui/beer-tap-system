[Unit]
Description=Tap Display Agent
After=network-online.target beer-tap-controller.service
Wants=network-online.target beer-tap-controller.service

[Service]
Type=simple
WorkingDirectory=/home/cybeer/beer-tap-system/tap-display-agent
Environment=PYTHONUNBUFFERED=1
Environment=DEVICE_ENV_PATH=/etc/beer-tap/device.env
RuntimeDirectory=beer-tap
RuntimeDirectoryMode=0755
ExecStart=/home/cybeer/.local/share/beer-tap/venvs/display-agent/bin/uvicorn main:app --host 127.0.0.1 --port 18181
Restart=always
RestartSec=3
User=cybeer
Group=cybeer

[Install]
WantedBy=multi-user.target
