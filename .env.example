# PostgreSQL (docker-compose)
POSTGRES_USER=beer_user
POSTGRES_PASSWORD=beer_password
POSTGRES_DB=beer_tap_db

# Backend database URL (used by SQLAlchemy)
DATABASE_URL=postgresql://beer_user:beer_password@postgres:5432/beer_tap_db

# Security baseline
# Backend will refuse to start with a placeholder or missing SECRET_KEY unless you explicitly opt in to the insecure dev fallback.
SECRET_KEY=replace-with-a-long-random-secret
ALLOW_INSECURE_DEV_SECRET_KEY=false
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Controller/internal service token.
# Set INTERNAL_TOKEN to the same value only for legacy compatibility with current Pi controller env files.
INTERNAL_API_KEY=replace-with-internal-service-token
INTERNAL_TOKEN=replace-with-internal-service-token
# INTERNAL_API_KEYS=replace-with-old-token,replace-with-new-token

# Display read-only token for tap-display-agent.
# Required on the backend side when the display path is deployed.
DISPLAY_API_KEY=replace-with-display-read-token
# DISPLAY_API_KEYS=replace-with-old-display-token,replace-with-new-display-token

# Legacy/demo token compatibility is now explicit opt-in.
ALLOW_LEGACY_DEMO_INTERNAL_TOKEN=false

# Bootstrap operator login for controlled pilot or local development.
# This is still not production-grade IAM; it just removes the hardcoded fake-password contract.
ENABLE_BOOTSTRAP_AUTH=true
BOOTSTRAP_AUTH_PASSWORD=replace-with-bootstrap-operator-password

# Comma-separated origins for admin-app web/dev access.
# Keep this explicit in pilot instead of using wildcard CORS.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional override for runtime media asset storage when backend is not started via docker-compose.
# docker-compose mounts backend_media_assets at /srv/beer-media-assets and sets this automatically.
# MEDIA_STORAGE_ROOT=/srv/beer-media-assets
